{
  "expo": {
    "name": "Daewoo Garage",
    "slug": "daewoo-garage",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "daewoogarage",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#111827"
      },
      "package": "com.daewoogarage.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikacja potrzebuje dostępu do galerii, aby dodać zdjęcie auta do garażu."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
